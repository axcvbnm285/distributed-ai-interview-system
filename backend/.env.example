# Local development database URL.
# Docker Compose overrides this value for the backend container to use the bundled `db` service.
# If you run the backend container against a Postgres instance on your host machine,
# replace `localhost` with `host.docker.internal` on macOS/Windows.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_platform?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="12h"
BCRYPT_ROUNDS="12"
PASSWORD_RESET_TTL_MINUTES="60"

FRONTEND_URL="http://localhost:5173"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password"
MAIL_FROM="InterviewFlow <your-email@example.com>"

GROQ_API_KEY="your-groq-key"
GROQ_MODEL="llama-3.1-8b-instant"
